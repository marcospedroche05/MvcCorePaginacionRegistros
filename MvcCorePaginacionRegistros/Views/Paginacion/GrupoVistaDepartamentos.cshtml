@model List<VistaDepartamento>



<h1>Paginacion en grupo</h1>

<hr/>
@{
    int numpagina = 1;
    int numRegistros = (int)ViewData["NUMREGISTROS"];
    <div>
        @for (int i = 1; i <= numRegistros; i += 2)
        {
            <a asp-controller="Paginacion" asp-action="GrupoVistaDepartamentos" asp-route-posicion="@i">Pagina @numpagina</a>
            numpagina += 1;
        }
    </div>
}
<hr/>

<table class="table table-warning">
    <thead>
        <tr>
            <th>Posicion</th>
            <th>Id</th>
            <th>Nombre</th>
            <th>Localidad</th>
        </tr>
    </thead>
    <tbody>
        @foreach(VistaDepartamento dept in Model)
        {
            <tr>
                <td>@dept.Posicion</td>
                <td>@dept.IdDepartamento</td>
                <td>@dept.Nombre</td>
                <td>@dept.Localidad</td>
            </tr>
        }
    </tbody>
</table>